<file path="src/HabitPage.css">
:root{--bg:#f6f8f7;--paper:#fff;--soft:#eef6f2;--line:#dce7e3;--ink:#1f2d2b;--muted:#667572;--green:#23796e;--deep:#145d54;--coral:#d66d52;--gold:#b98520;--rose:#c95661;--blue:#527fa0;--shadow:0 16px 38px rgba(24,48,45,.12);--r:8px}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;color:var(--ink);    
background:linear-gradient(135deg,rgba(35,121,110,.08),transparent 34%),linear-gradient(225deg,rgba(214,109,82,.08),transparent 36%),var(--bg);font-family:"Segoe UI","Noto Sans TC",Arial,sans-serif;letter-spacing:0}button,select{font:inherit;letter-spacing:0}button{cursor:pointer}button:disabled{opacity:.38;cursor:not-allowed}

.app{width:min(1240px,calc(100% - 32px));margin:auto;padding:22px 0 48px}
.top{display:grid;grid-template-columns:1fr auto;gap:18px;align-items:end;
     padding:18px;
     margin-bottom:14px;
     border:1px solid var(--line);
     
     border-radius:var(--r);
     background:rgba(255,255,255,.9);
     box-shadow:var(--shadow)}.eyebrow{display:inline-flex;gap:8px;color:var(--deep);font-size:13px;font-weight:800;margin-bottom:8px}h1,h2,h3,h4,p{margin-top:0}h1{margin-bottom:8px;font-size:clamp(26px,4vw,40px);line-height:1.18}.top p,.intro p,.muted{color:var(--muted);line-height:1.75}.top p{max-width:760px;margin-bottom:0}label{display:block;margin-bottom:6px;color:var(--muted);font-size:12px;font-weight:800}select{min-width:230px;padding:11px 12px;border:1px solid var(--line);border-radius:var(--r);background:#fff;color:var(--ink)}
.tabs{position:sticky;top:0;z-index:20;display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px;padding:8px;border:1px solid var(--line);border-radius:var(--r);background:rgba(246,248,247,.92);backdrop-filter:blur(10px)}.tab{border:1px solid transparent;border-radius:var(--r);padding:13px 16px;background:#fff;color:var(--muted);font-weight:900;transition:.18s}.tab:hover{color:var(--deep);border-color:rgba(35,121,110,.3)}.tab.active{color:#fff;background:linear-gradient(135deg,var(--green),var(--deep));box-shadow:0 10px 20px rgba(35,121,110,.18)}
.intro{display:grid;grid-template-columns:1fr auto;gap:16px;align-items:end;margin-bottom:16px}.intro h2{margin-bottom:8px;font-size:clamp(24px,3vw,34px)}.intro p{max-width:780px;margin-bottom:0}.note{max-width:300px;padding:12px 14px;border:1px solid var(--line);border-radius:var(--r);background:rgba(255,255,255,.78);color:var(--muted);font-size:13px;line-height:1.65}.panel{border:1px solid var(--line);border-radius:var(--r);background:rgba(255,255,255,.94);box-shadow:var(--shadow);overflow:hidden}.pad{padding:18px}.head{display:flex;justify-content:space-between;gap:12px;margin-bottom:14px}.head h3{margin:0;font-size:20px}.head p{margin:4px 0 0;color:var(--muted);font-size:13px;line-height:1.6}.stack{display:grid;gap:18px}
.time-hero{display:grid;grid-template-columns:minmax(0,2.1fr) minmax(300px,.9fr);gap:18px;align-items:stretch}.calendar-wrap{min-height:100%}.calendar-wrap .head{padding-bottom:4px}.calendar{display:grid;grid-template-columns:repeat(7,1fr);gap:9px}.w{text-align:center;color:var(--muted);font-size:12px;font-weight:900}.day{min-height:74px;display:flex;flex-direction:column;justify-content:space-between;align-items:flex-start;padding:10px;border:1px solid var(--line);border-radius:var(--r);background:#fff;transition:.18s}.day.has:hover,.summary-card:hover,.photo-card:hover,.feature-card:hover{transform:translateY(-3px);border-color:rgba(35,121,110,.35);box-shadow:0 12px 28px rgba(24,48,45,.1)}.day.empty{cursor:default;opacity:.28;background:#f8fbfa}.selected{border-color:rgba(35,121,110,.72)!important;box-shadow:0 12px 24px rgba(35,121,110,.16)!important}.day.selected{color:#fff;border-color:transparent!important;background:linear-gradient(135deg,var(--green),var(--deep))}.num{font-weight:900}.markers{display:flex;align-items:center;gap:5px;font-size:12px}.dot{width:8px;height:8px;border-radius:999px;background:var(--blue)}.dot.開心{background:var(--green)}.dot.平靜{background:var(--blue)}.dot.低落{background:var(--gold)}.dot.焦慮{background:var(--rose)}
.day-summary{min-height:100%;display:flex;flex-direction:column}.summary-cover{padding:18px;color:#fff;background:linear-gradient(135deg,rgba(35,121,110,.96),rgba(20,93,84,.9))}.summary-cover .eyebrow{color:rgba(255,255,255,.84)}.summary-cover h3{margin:6px 0 4px;font-size:24px}.summary-cover p{margin:0;color:rgba(255,255,255,.82);line-height:1.6}.summary-body{display:flex;flex-direction:column;gap:14px;padding:18px;flex:1}.summary-body .summary{font-size:14px}.summary-status{display:grid;grid-template-columns:1fr;gap:8px}.summary-status .pill{justify-content:flex-start;width:max-content}.summary-actions{margin-top:auto}.summary-actions .btn{width:100%}
.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.summary-card,.photo-card,.feature-card{border:1px solid var(--line);border-radius:var(--r);background:#fff;cursor:pointer;transition:.18s;overflow:hidden}.summary-card{padding:15px}.meta{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;margin-bottom:10px}.date{font-weight:900}.summary{margin:0;color:var(--muted);font-size:13px;line-height:1.65}.tiny-row{display:flex;flex-wrap:wrap;gap:7px;margin-top:10px}.pill{display:inline-flex;align-items:center;gap:5px;padding:6px 9px;border-radius:999px;background:var(--soft);color:var(--muted);font-size:12px;font-weight:900;white-space:nowrap}.happy{color:#14624f;background:rgba(35,121,110,.12)}.calm{color:#4b6b91;background:rgba(82,127,160,.13)}.low,.gold{color:#80601d;background:rgba(185,133,32,.14)}.anx,.warn{color:#9a3e49;background:rgba(201,86,97,.13)}
.collapse{border:1px solid var(--line);border-radius:var(--r);background:#fff;overflow:hidden}.toggle{width:100%;display:flex;justify-content:space-between;gap:12px;padding:14px 16px;border:0;background:#fff;color:var(--ink);font-weight:900;text-align:left}.toggle:hover{background:#f8fbfa}.more{display:none;padding:0 16px 16px}.collapse.open .more{display:block}.more-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.empty{padding:20px;border:1px dashed rgba(35,121,110,.38);border-radius:var(--r);background:linear-gradient(135deg,rgba(238,246,242,.95),rgba(255,244,239,.86))}.empty p{margin-bottom:0;color:var(--muted);line-height:1.75}
.photo-wall{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-flow:dense;gap:12px}.photo-card.big{grid-column:span 2;grid-row:span 2}.thumb,.modal-image,.slide-image,.feature-thumb{background:var(--thumb);position:relative}.thumb{min-height:150px;aspect-ratio:1/1}.big .thumb{aspect-ratio:1.16/1}.thumb:after,.feature-thumb:after,.slide-image:after,.modal-image:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 35%,rgba(24,45,42,.34))}.photo-mark{position:absolute;right:10px;bottom:10px;z-index:1;color:#fff;font-weight:900;text-shadow:0 2px 8px rgba(0,0,0,.28)}.caption{padding:12px}.caption h4{margin:0;font-size:15px}.caption p{display:none;margin:6px 0 0;color:var(--muted);font-size:13px;line-height:1.5}.photo-card.big .caption p{display:block}.feature-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.feature-card{padding:14px}.feature-thumb{height:112px;margin:-14px -14px 12px}.feature-card h4{margin:8px 0 6px;font-size:16px}.feature-card p{margin:0;color:var(--muted);font-size:13px;line-height:1.55}
dialog{width:min(920px,calc(100% - 24px));border:0;border-radius:var(--r);padding:0;color:var(--ink);background:#fff;box-shadow:0 30px 80px rgba(16,35,32,.28)}dialog::backdrop{background:rgba(18,35,33,.46);backdrop-filter:blur(3px)}.modal-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.82fr);min-height:540px}.modal-image{min-height:540px}.modal-side{display:flex;flex-direction:column;gap:14px;padding:22px}.modal-top{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.icon-btn{width:38px;height:38px;border:1px solid var(--line);border-radius:var(--r);background:#fff;color:var(--muted);font-weight:900}.icon-btn:hover{color:var(--deep);background:var(--soft)}.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.stat,.soft-box{padding:12px;border:1px solid var(--line);border-radius:var(--r);background:#fff}.soft-box{background:#f9fbfa}.stat span{display:block;color:var(--muted);font-size:12px;font-weight:900}.stat strong{display:block;margin-top:5px;font-size:17px}.soft-box h4{margin:0 0 8px;font-size:15px}.soft-box p{margin:0;color:var(--muted);line-height:1.75}.progress-line{display:flex;justify-content:space-between;gap:10px;margin-bottom:8px;font-weight:900}.progress{height:9px;border-radius:999px;background:#dfe9e5;overflow:hidden}.progress span{display:block;height:100%;background:linear-gradient(90deg,var(--green),#69aa94)}.actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:auto}.btn{border:1px solid transparent;border-radius:var(--r);padding:10px 12px;font-weight:900;transition:.18s}.btn:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(24,48,45,.1)}.primary{color:#fff;background:var(--coral)}.secondary{color:var(--deep);background:var(--soft);border-color:rgba(35,121,110,.18)}.plain{color:var(--muted);background:#fff;border-color:var(--line)}
.day-modal{width:min(720px,calc(100% - 24px))}.photo-dots{display:flex;gap:6px}.photo-dot{width:8px;height:8px;border-radius:999px;background:rgba(255,255,255,.45);position:relative;z-index:1}.photo-dot.active{background:#fff}.slide{width:min(1040px,calc(100% - 24px));height:min(760px,calc(100vh - 32px));background:#0f1a18;overflow:hidden}.slide-frame{position:relative;width:100%;height:100%;background:var(--thumb);background-size:cover}.slide-frame:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.08) 35%,rgba(7,18,16,.72) 100%)}.slide-copy{position:absolute;left:28px;bottom:28px;z-index:2;max-width:min(560px,calc(100% - 76px));color:#fff;text-shadow:0 2px 14px rgba(0,0,0,.34)}.slide-copy .pill{background:rgba(255,255,255,.14);color:rgba(255,255,255,.92)}.slide-copy h2{margin:12px 0 8px;font-size:clamp(24px,4vw,42px);line-height:1.12}.slide-copy p{margin:0 0 14px;color:rgba(255,255,255,.84);line-height:1.7}.slide-link{padding:0;border:0;background:transparent;color:rgba(255,255,255,.9);font-weight:900;text-decoration:underline;text-underline-offset:4px}.slide-link:hover{color:#fff}.slide-close,.slide-arrow{position:absolute;z-index:3;border:1px solid rgba(255,255,255,.22);background:rgba(0,0,0,.12);color:rgba(255,255,255,.82);transition:.18s}.slide-close{top:18px;right:18px;width:38px;height:38px;border-radius:var(--r);font-size:22px}.slide-arrow{top:50%;transform:translateY(-50%);width:44px;height:64px;border-radius:var(--r);font-size:34px;line-height:1}.slide-arrow.prev{left:18px}.slide-arrow.next{right:18px}.slide-close:hover,.slide-arrow:hover{background:rgba(0,0,0,.28);color:#fff;border-color:rgba(255,255,255,.42)}.slide-arrow:disabled{opacity:.2}.slide-count{position:absolute;right:22px;bottom:20px;z-index:2;color:rgba(255,255,255,.72);font-size:12px;font-weight:800}.toast{position:fixed;right:20px;bottom:20px;z-index:90;width:min(360px,calc(100% - 40px));padding:14px 16px;border-radius:var(--r);color:#fff;background:rgba(30,44,42,.94);box-shadow:var(--shadow);line-height:1.55;opacity:0;transform:translateY(16px);pointer-events:none;transition:.22s}.toast.show{opacity:1;transform:translateY(0)}
@media(max-width:1080px){.top,.intro,.time-hero,.modal-grid{grid-template-columns:1fr}.photo-wall{grid-template-columns:repeat(3,1fr)}.summary-grid,.feature-row{grid-template-columns:repeat(2,1fr)}.more-grid{grid-template-columns:repeat(3,1fr)}.modal-image{min-height:360px}}@media(max-width:720px){.app{width:min(100% - 24px,1240px);padding-top:14px}.tabs{position:static}.calendar{gap:6px}.day{min-height:54px;padding:7px}.photo-wall,.summary-grid,.feature-row,.more-grid,.stats{grid-template-columns:1fr}.photo-card.big{grid-column:span 1;grid-row:span 1}.top,.pad,.modal-side,.summary-body{padding:14px}.actions .btn{flex:1}.slide{height:min(680px,calc(100vh - 20px))}.slide-copy{left:18px;bottom:22px}.slide-arrow{width:38px;height:54px}.slide-arrow.prev{left:10px}.slide-arrow.next{right:10px}}
</file>

<file path="src/Icon.jsx">

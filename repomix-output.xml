    CONSTRAINT CK_task_title_not_blank
        CHECK (LEN(LTRIM(RTRIM(title))) > 0),
    CONSTRAINT CK_task_rhythm_type
        CHECK (rhythm_type IN (N'Daily', N'NonDaily')),
    CONSTRAINT CK_task_status
        CHECK (status IN (N'Active', N'Archived'))
);

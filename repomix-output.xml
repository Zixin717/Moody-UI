    }
  };

  /* ======================================== 事件：通知開關點擊 =========================================== */
  const handleToggleNotification = async () => {
    // 1. 取得切換後的新狀態 (原本是 true 就變 false)
    const newStatus = !editData.isNotificationEnabled;
    
    // 2. optimistic UI
    setEditData({ ...editData, isNotificationEnabled: newStatus });

